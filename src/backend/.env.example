# =============================================================================
# Westbrook Community Library – Backend Environment Variables
# Copy this file to .env and fill in the values before running the server.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# -----------------------------------------------------------------------------
# Database (PostgreSQL 15+)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=westbrook_library
DB_USER=westbrook_user
DB_PASSWORD=changeme_strong_password
# Connection pool size (recommended: 2 * CPU cores + 1 for a small VPS)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=replace_with_64_byte_random_hex_string
JWT_EXPIRES_IN=8h
# Shorter-lived refresh token (if implemented later)
JWT_REFRESH_SECRET=replace_with_another_64_byte_random_hex_string
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash)
# Development: http://localhost:5173 (Vite default)
# Production: https://library.westbrook.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# bcrypt salt rounds (10–12 recommended; higher = slower but more secure)
BCRYPT_SALT_ROUNDS=12
# Rate limiting: max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
